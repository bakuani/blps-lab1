      <outgoing>Flow_T_DBUp</outgoing>
      <dataOutputAssociation id="DOA_UpdateTariff">
        <targetRef>DS_SubscriberTariffs</targetRef>
      </dataOutputAssociation>
    </serviceTask>
    <serviceTask id="Task_LoadTariffsByCategory" name="Загрузить тарифы&#10;по категории">
