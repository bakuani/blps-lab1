      <outgoing>Flow_T6b_Cat</outgoing>
      <dataOutputAssociation id="DataOutputAssociation_0i80og8">
        <targetRef>DS_Tariffs</targetRef>
      </dataOutputAssociation>
    </serviceTask>
    <serviceTask id="Task_LoadFeatureDetails" name="Загрузить описание&#10;услуги">
