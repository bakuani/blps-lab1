      <outgoing>Flow_T6b_Search</outgoing>
      <dataOutputAssociation id="DataOutputAssociation_0fdjjfr">
        <targetRef>DS_Tariffs</targetRef>
      </dataOutputAssociation>
    </serviceTask>
    <exclusiveGateway id="Gateway_ChangeResult" name="Результат&#10;смены?">
      <incoming>Flow_T_DBUp</incoming>
      <outgoing>Flow_T_OK</outgoing>
      <outgoing>Flow_T_Err</outgoing>
    </exclusiveGateway>
    <endEvent id="EndEvent_TariffError" name="Ошибка смены&#10;тарифа">
      <incoming>Flow_T_NE</incoming>
    </endEvent>
    <endEvent id="EndEvent_TariffChanged" name="Тариф успешно&#10;изменён">
      <incoming>Flow_T_ULK</incoming>
    </endEvent>
    <sendTask id="Task_NotifyError" name="Уведомление:&#10;ошибка смены тарифа">
      <incoming>Flow_T_Err</incoming>
      <outgoing>Flow_T_NE</outgoing>
    </sendTask>
    <sendTask id="Task_NotifySuccess" name="Уведомление:&#10;тариф изменён (SMS+push)">
      <incoming>Flow_T_OK</incoming>
      <outgoing>Flow_T_NS</outgoing>
    </sendTask>
    <serviceTask id="Task_UpdateLK_Tariff" name="Обновить данные&#10;в ЛК">
      <incoming>Flow_T_NS</incoming>
      <outgoing>Flow_T_ULK</outgoing>
    </serviceTask>
    <startEvent id="StartEvent_Main" name="Абонент открывает&#10;Личный кабинет">
      <outgoing>Flow_S1</outgoing>
    </startEvent>
    <exclusiveGateway id="Gateway_Section" name="Выбор раздела">
      <incoming>Flow_S1</incoming>
      <outgoing>Flow_ToTariff</outgoing>
      <outgoing>Flow_ToServices</outgoing>
