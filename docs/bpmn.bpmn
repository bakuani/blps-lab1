      </dataOutputAssociation>
      <dataOutputAssociation id="DataOutputAssociation_1094d0j">
        <targetRef>DS_Services</targetRef>
      </dataOutputAssociation>
    </serviceTask>
    <serviceTask id="Task_LoadTariffInfo" name="Загрузить информацию&#10;о тарифе и балансе">
