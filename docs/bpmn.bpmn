      <outgoing>Flow_U7c_Details</outgoing>
      <dataOutputAssociation id="DataOutputAssociation_101gam2">
        <targetRef>DS_Services</targetRef>
      </dataOutputAssociation>
    </serviceTask>
    <endEvent id="EndEvent_FeatureDetails" name="Страница услуги&#10;отображена">
      <incoming>Flow_U7c_Details</incoming>
    </endEvent>
