    <dataStoreReference id="DS_Tariffs" name="tariff" />
    <dataStoreReference id="DS_Balances" name="balance" />
    <dataStoreReference id="DS_TariffCategories" name="tariff_category" />
    <dataStoreReference id="DS_TariffOptions" name="tariff_option" />
    <dataStoreReference id="DS_SubscriberTariffs" name="subscriber_tariff" />
    <dataStoreReference id="DS_Services" name="service" />
    <dataStoreReference id="DS_SubscriberFeatures" />
    <serviceTask id="Task_LoadServices" name="Загрузить список&#10;подключённых услуг">
