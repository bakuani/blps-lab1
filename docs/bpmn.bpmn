      </dataOutputAssociation>
      <dataOutputAssociation id="DataOutputAssociation_1p3i3nv">
        <targetRef>DS_Balances</targetRef>
      </dataOutputAssociation>
    </serviceTask>
    <serviceTask id="Task_LoadCategories" name="Загрузить категории&#10;тарифов">
