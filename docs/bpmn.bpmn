        <targetRef>DS_TariffOptions</targetRef>
      </dataOutputAssociation>
      <dataOutputAssociation id="DataOutputAssociation_1rrean1">
        <targetRef>DS_Tariffs</targetRef>
      </dataOutputAssociation>
    </serviceTask>
    <exclusiveGateway id="Gateway_IsCustomizable" name="Тариф&#10;кастомизируется?">
      <incoming>Flow_T_Name4</incoming>
      <outgoing>Flow_T_CustYes</outgoing>
      <outgoing>Flow_T_CustNo</outgoing>
