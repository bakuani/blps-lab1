    <userTask id="Task_SelectTariffFromCategory" name="Выбрать тариф&#10;из категории">
      <incoming>Flow_T6b_Cat</incoming>
      <outgoing>Flow_T7_Cat</outgoing>
    </userTask>
    <exclusiveGateway id="Gateway_TariffMerge">
      <incoming>Flow_T7_Cat</incoming>
      <incoming>Flow_T6b_Search</incoming>
      <outgoing>Flow_T8</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="Gateway_TariffDetailAction" name="Действие&#10;с тарифом">
