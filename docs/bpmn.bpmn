    <serviceTask id="Task_BillingChargeMonthly" name="Биллинг: списать&#10;абонентскую плату&#10;нового тарифа">
      <incoming>Flow_T_FM</incoming>
      <outgoing>Flow_T_BCM</outgoing>
    </serviceTask>
    <serviceTask id="Task_UpdateSubscriberTariff" name="Обновить тариф&#10;абонента в БД">
