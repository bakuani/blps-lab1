      "parentId": "fld_tariff",
      "name": "Change tariff",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/subscribers/{{ _.subscriber_id }}/tariff/change",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"targetTariffId\": {{ _.tariff_id }},\n  \"options\": {\n    \"minutes\": \"+200\",\n    \"internet\": \"+20GB\"\n  }\n}"
      },
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ]
    },
    {
      "_id": "req_get_services",
      "_type": "request",
      "parentId": "fld_service",
      "name": "Get subscriber services",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/subscribers/{{ _.subscriber_id }}/services"
    },
    {
      "_id": "req_get_service_categories",
      "_type": "request",
      "parentId": "fld_service",
      "name": "Get service categories",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/services/categories"
    },
    {
      "_id": "req_search_services",
      "_type": "request",
      "parentId": "fld_service",
