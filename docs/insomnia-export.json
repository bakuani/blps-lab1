      "parentId": "wrk_blps",
      "name": "Base Environment",
      "data": {
        "base_url": "http://localhost:8080",
        "subscriber_id": 1,
        "tariff_id": 2,
        "service_id": 1,
        "category_id": 1
      }
    },
    {
      "_id": "fld_tariff",
      "_type": "request_group",
      "parentId": "wrk_blps",
      "name": "Tariff flow"
    },
    {
