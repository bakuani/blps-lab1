      "parentId": "wrk_blps",
      "name": "Services flow"
    },
    {
      "_id": "req_get_tariff_info",
      "_type": "request",
      "parentId": "fld_tariff",
      "name": "Get subscriber tariff info",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/subscribers/{{ _.subscriber_id }}/tariff"
    },
    {
      "_id": "req_get_tariff_categories",
      "_type": "request",
      "parentId": "fld_tariff",
      "name": "Get tariff categories",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/tariffs/categories"
    },
    {
      "_id": "req_search_tariffs",
      "_type": "request",
      "parentId": "fld_tariff",
      "name": "Search tariffs",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/tariffs?categoryId={{ _.category_id }}&query=мой"
    },
    {
      "_id": "req_tariff_details",
      "_type": "request",
      "parentId": "fld_tariff",
      "name": "Get tariff details",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/tariffs/{{ _.tariff_id }}"
    },
    {
