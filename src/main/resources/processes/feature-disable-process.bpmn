      <bpmndi:BPMNShape id="Task_UpdateSubscriberFeature_di" bpmnElement="Task_UpdateSubscriberFeature">
        <dc:Bounds x="940" y="250" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyFeatureDisable_di" bpmnElement="Task_NotifyFeatureDisable">
        <dc:Bounds x="1130" y="250" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AuditFeatureDisable_di" bpmnElement="Task_AuditFeatureDisable">
        <dc:Bounds x="1310" y="250" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_FeatureDisable_di" bpmnElement="End_FeatureDisable">
        <dc:Bounds x="1500" y="272" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1486" y="308" width="64" height="40" />
