          <dc:Bounds x="794" y="500" width="89" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DS_Feature_Subscriber_di" bpmnElement="DS_Feature_Subscriber">
        <dc:Bounds x="615" y="450" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="615" y="500" width="51" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DS_Feature_SubscriberFeature_di" bpmnElement="DS_Feature_SubscriberFeature">
