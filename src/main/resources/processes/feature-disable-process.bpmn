<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" targetNamespace="http://callmeani.urasha.ru/blps/camunda" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.16.0">
  <bpmn:process id="FeatureDisableProcess" name="Отключение услуги" isExecutable="true" camunda:historyTimeToLive="30" camunda:candidateStarterGroups="SUBSCRIBER,OPERATOR,ADMIN">
    <bpmn:laneSet id="LaneSet_FeatureDisable">
      <bpmn:lane id="Lane_Feature_Db" name="База данных" />
      <bpmn:lane id="Lane_Feature_App" name="Приложение">
        <bpmn:flowNodeRef>Task_ValidateFeatureDisable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DisableFeatureBilling</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UpdateSubscriberFeature</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_NotifyFeatureDisable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AuditFeatureDisable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_FeatureDisable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_CanDisableFeature</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Feature_User" name="Пользователь">
        <bpmn:flowNodeRef>Task_CreateFeatureDisableRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Start_FeatureDisable</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_FeatureDisable" name="Начать отключение услуги">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="subscriberId" label="ID subscriber" type="long" />
          <camunda:formField id="featureId" label="Feature ID" type="long" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_F_Start_Form</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_CreateFeatureDisableRequest" name="Create feature disable request" camunda:type="external" camunda:topic="create-feature-disable-request">
      <bpmn:incoming>Flow_F_Start_Form</bpmn:incoming>
      <bpmn:outgoing>Flow_F_Form_Validate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ValidateFeatureDisable" name="Проверить отключение услуги" camunda:type="external" camunda:topic="validate-feature-disable">
      <bpmn:incoming>Flow_F_Form_Validate</bpmn:incoming>
      <bpmn:outgoing>Flow_F_Validate_CanDisable</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1homhug">
        <bpmn:targetRef>DS_Feature_SubscriberFeature</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_009l9zg">
        <bpmn:targetRef>DS_Feature_Request</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1hu26x3">
        <bpmn:targetRef>DS_Feature_Subscriber</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_CanDisableFeature" name="Отключение разрешено?">
      <bpmn:incoming>Flow_F_Validate_CanDisable</bpmn:incoming>
      <bpmn:outgoing>Flow_F_CanDisable_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_F_CanDisable_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_DisableFeatureBilling" name="Выполнить биллинг отключения" camunda:type="external" camunda:topic="disable-feature-billing">
      <bpmn:incoming>Flow_F_CanDisable_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_F_Billing_Update</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_UpdateSubscriberFeature" name="Обновить услугу абонента" camunda:type="external" camunda:topic="update-subscriber-feature">
      <bpmn:incoming>Flow_F_Billing_Update</bpmn:incoming>
      <bpmn:outgoing>Flow_F_Update_Notify</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_0wgy0i9">
        <bpmn:targetRef>DS_Feature_SubscriberFeature</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Task_NotifyFeatureDisable" name="Отправить уведомление" camunda:type="external" camunda:topic="send-notification">
      <bpmn:incoming>Flow_F_Update_Notify</bpmn:incoming>
      <bpmn:outgoing>Flow_F_Notify_Audit</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:serviceTask id="Task_AuditFeatureDisable" name="Записать аудит EIS" camunda:type="external" camunda:topic="publish-eis-audit">
      <bpmn:incoming>Flow_F_Notify_Audit</bpmn:incoming>
      <bpmn:incoming>Flow_F_CanDisable_No</bpmn:incoming>
      <bpmn:outgoing>Flow_F_Audit_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_FeatureDisable" name="Отключение услуги завершено">
      <bpmn:incoming>Flow_F_Audit_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:dataStoreReference id="DS_Feature_Request" name="feature_disable_request" />
    <bpmn:dataStoreReference id="DS_Feature_Subscriber" name="subscriber" />
    <bpmn:dataStoreReference id="DS_Feature_SubscriberFeature" name="subscriber_feature" />
    <bpmn:dataStoreReference id="DS_Feature_BillingTransaction" name="billing_transaction" />
    <bpmn:dataStoreReference id="DS_Feature_NotificationEvent" name="notification_event" />
    <bpmn:dataStoreReference id="DS_Feature_EisAudit" name="eis_audit" />
    <bpmn:sequenceFlow id="Flow_F_Start_Form" sourceRef="Start_FeatureDisable" targetRef="Task_CreateFeatureDisableRequest" />
    <bpmn:sequenceFlow id="Flow_F_Form_Validate" sourceRef="Task_CreateFeatureDisableRequest" targetRef="Task_ValidateFeatureDisable" />
    <bpmn:sequenceFlow id="Flow_F_Validate_CanDisable" sourceRef="Task_ValidateFeatureDisable" targetRef="Gateway_CanDisableFeature" />
    <bpmn:sequenceFlow id="Flow_F_CanDisable_Yes" name="Да" sourceRef="Gateway_CanDisableFeature" targetRef="Task_DisableFeatureBilling">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${canDisableFeature}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_F_CanDisable_No" name="Нет" sourceRef="Gateway_CanDisableFeature" targetRef="Task_AuditFeatureDisable">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!canDisableFeature}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_F_Billing_Update" sourceRef="Task_DisableFeatureBilling" targetRef="Task_UpdateSubscriberFeature" />
    <bpmn:sequenceFlow id="Flow_F_Update_Notify" sourceRef="Task_UpdateSubscriberFeature" targetRef="Task_NotifyFeatureDisable" />
    <bpmn:sequenceFlow id="Flow_F_Notify_Audit" sourceRef="Task_NotifyFeatureDisable" targetRef="Task_AuditFeatureDisable" />
    <bpmn:sequenceFlow id="Flow_F_Audit_End" sourceRef="Task_AuditFeatureDisable" targetRef="End_FeatureDisable" />
    <bpmn:association id="Assoc_F_Billing_Transaction" associationDirection="One" sourceRef="Task_DisableFeatureBilling" targetRef="DS_Feature_BillingTransaction" />
    <bpmn:association id="Assoc_F_Notify_Event" associationDirection="One" sourceRef="Task_NotifyFeatureDisable" targetRef="DS_Feature_NotificationEvent" />
    <bpmn:association id="Assoc_F_Audit_Eis" associationDirection="One" sourceRef="Task_AuditFeatureDisable" targetRef="DS_Feature_EisAudit" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_FeatureDisableProcess">
    <bpmndi:BPMNPlane id="BPMNPlane_FeatureDisableProcess" bpmnElement="FeatureDisableProcess">
      <bpmndi:BPMNShape id="Lane_Feature_Db_di" bpmnElement="Lane_Feature_Db" isHorizontal="true">
        <dc:Bounds x="160" y="380" width="1420" height="190" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Feature_App_di" bpmnElement="Lane_Feature_App" isHorizontal="true">
