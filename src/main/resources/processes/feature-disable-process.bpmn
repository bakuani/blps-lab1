        <bpmndi:BPMNLabel>
          <dc:Bounds x="723" y="265" width="14" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_F_CanDisable_No_di" bpmnElement="Flow_F_CanDisable_No">
