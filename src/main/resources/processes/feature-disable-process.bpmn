        <di:waypoint x="675" y="355" />
        <di:waypoint x="1360" y="355" />
        <di:waypoint x="1360" y="330" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="690" y="321" width="19" height="14" />
