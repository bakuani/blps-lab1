          <dc:Bounds x="1358" y="500" width="45" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DS_Feature_BillingTransaction_di" bpmnElement="DS_Feature_BillingTransaction">
        <dc:Bounds x="813" y="450" width="50" height="50" />
