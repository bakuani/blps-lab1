          <dc:Bounds x="449" y="500" width="86" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Assoc_F_Billing_Transaction_di" bpmnElement="Assoc_F_Billing_Transaction">
