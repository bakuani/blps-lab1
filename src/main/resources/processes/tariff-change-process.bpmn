<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" targetNamespace="http://callmeani.urasha.ru/blps/camunda" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.16.0">
  <bpmn:process id="TariffChangeProcess" name="Смена тарифа" isExecutable="true" camunda:historyTimeToLive="30" camunda:candidateStarterGroups="SUBSCRIBER,OPERATOR,ADMIN">
    <bpmn:laneSet id="LaneSet_TariffChange">
      <bpmn:lane id="Lane_Tariff_Db" name="База данных" />
      <bpmn:lane id="Lane_Tariff_App" name="Приложение">
        <bpmn:flowNodeRef>Task_ValidateTariffChange</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_TariffChargesMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ChargeNewMonthlyFee</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UpdateSubscriberTariff</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_NotifyTariffChange</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AuditTariffChange</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ChargeSwitchFee</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_HasSwitchFee</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_TariffChange</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_CanChangeTariff</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Tariff_User" name="Пользователь">
        <bpmn:flowNodeRef>Task_CreateTariffChangeRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Start_TariffChange</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_TariffChange" name="Начать смену тарифа">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="subscriberId" label="ID subscriber" type="long" />
          <camunda:formField id="targetTariffId" label="Target tariff ID" type="long" />
          <camunda:formField id="options" label="Options JSON" type="string" defaultValue="{}" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_T_Start_Form</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_CreateTariffChangeRequest" name="Create tariff change request" camunda:type="external" camunda:topic="create-tariff-change-request">
      <bpmn:incoming>Flow_T_Start_Form</bpmn:incoming>
      <bpmn:outgoing>Flow_T_Form_Validate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ValidateTariffChange" name="Проверить смену тарифа" camunda:type="external" camunda:topic="validate-tariff-change">
      <bpmn:incoming>Flow_T_Form_Validate</bpmn:incoming>
      <bpmn:outgoing>Flow_T_Validate_CanChange</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_00pv7k7">
        <bpmn:targetRef>DS_Tariff_Subscriber</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_CanChangeTariff" name="Смена разрешена?">
      <bpmn:incoming>Flow_T_Validate_CanChange</bpmn:incoming>
      <bpmn:outgoing>Flow_T_CanChange_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_T_CanChange_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_HasSwitchFee" name="Есть плата за смену?">
      <bpmn:incoming>Flow_T_CanChange_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_T_SwitchFee_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_T_SwitchFee_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_ChargeSwitchFee" name="Списать плату за смену" camunda:type="external" camunda:topic="charge-switch-fee">
      <bpmn:incoming>Flow_T_SwitchFee_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_T_SwitchFee_Merge</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_0905iez">
        <bpmn:targetRef>DS_Tariff_Subscriber</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_TariffChargesMerge">
      <bpmn:incoming>Flow_T_SwitchFee_Merge</bpmn:incoming>
      <bpmn:incoming>Flow_T_SwitchFee_No</bpmn:incoming>
      <bpmn:outgoing>Flow_T_Merge_MonthlyFee</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_ChargeNewMonthlyFee" name="Списать абонентскую плату тарифа" camunda:type="external" camunda:topic="charge-new-monthly-fee">
      <bpmn:incoming>Flow_T_Merge_MonthlyFee</bpmn:incoming>
      <bpmn:outgoing>Flow_T_Monthly_UpdateTariff</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_UpdateSubscriberTariff" name="Обновить тариф абонента" camunda:type="external" camunda:topic="update-subscriber-tariff">
      <bpmn:incoming>Flow_T_Monthly_UpdateTariff</bpmn:incoming>
      <bpmn:outgoing>Flow_T_Update_Notify</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Task_NotifyTariffChange" name="Отправить уведомление" camunda:type="external" camunda:topic="send-notification">
      <bpmn:incoming>Flow_T_Update_Notify</bpmn:incoming>
      <bpmn:outgoing>Flow_T_Notify_Audit</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:serviceTask id="Task_AuditTariffChange" name="Записать аудит EIS" camunda:type="external" camunda:topic="publish-eis-audit">
      <bpmn:incoming>Flow_T_Notify_Audit</bpmn:incoming>
      <bpmn:incoming>Flow_T_CanChange_No</bpmn:incoming>
      <bpmn:outgoing>Flow_T_Audit_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_TariffChange" name="Смена тарифа завершена">
      <bpmn:incoming>Flow_T_Audit_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:dataStoreReference id="DS_Tariff_Request" name="tariff_change_request" />
    <bpmn:dataStoreReference id="DS_Tariff_Subscriber" name="subscriber" />
    <bpmn:dataStoreReference id="DS_Tariff_Tariff" name="tariff" />
    <bpmn:dataStoreReference id="DS_Tariff_BillingTransaction" name="billing_transaction" />
    <bpmn:dataStoreReference id="DS_Tariff_NotificationEvent" name="notification_event" />
    <bpmn:dataStoreReference id="DS_Tariff_EisAudit" name="eis_audit" />
    <bpmn:sequenceFlow id="Flow_T_Start_Form" sourceRef="Start_TariffChange" targetRef="Task_CreateTariffChangeRequest" />
    <bpmn:sequenceFlow id="Flow_T_Form_Validate" sourceRef="Task_CreateTariffChangeRequest" targetRef="Task_ValidateTariffChange" />
    <bpmn:sequenceFlow id="Flow_T_Validate_CanChange" sourceRef="Task_ValidateTariffChange" targetRef="Gateway_CanChangeTariff" />
    <bpmn:sequenceFlow id="Flow_T_CanChange_Yes" name="Да" sourceRef="Gateway_CanChangeTariff" targetRef="Gateway_HasSwitchFee">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${canChangeTariff}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T_CanChange_No" name="Нет" sourceRef="Gateway_CanChangeTariff" targetRef="Task_AuditTariffChange">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!canChangeTariff}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T_SwitchFee_Yes" name="Да" sourceRef="Gateway_HasSwitchFee" targetRef="Task_ChargeSwitchFee">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${hasSwitchFee}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T_SwitchFee_No" name="Нет" sourceRef="Gateway_HasSwitchFee" targetRef="Gateway_TariffChargesMerge">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!hasSwitchFee}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T_SwitchFee_Merge" sourceRef="Task_ChargeSwitchFee" targetRef="Gateway_TariffChargesMerge" />
    <bpmn:sequenceFlow id="Flow_T_Merge_MonthlyFee" sourceRef="Gateway_TariffChargesMerge" targetRef="Task_ChargeNewMonthlyFee" />
    <bpmn:sequenceFlow id="Flow_T_Monthly_UpdateTariff" sourceRef="Task_ChargeNewMonthlyFee" targetRef="Task_UpdateSubscriberTariff" />
    <bpmn:sequenceFlow id="Flow_T_Update_Notify" sourceRef="Task_UpdateSubscriberTariff" targetRef="Task_NotifyTariffChange" />
    <bpmn:sequenceFlow id="Flow_T_Notify_Audit" sourceRef="Task_NotifyTariffChange" targetRef="Task_AuditTariffChange" />
    <bpmn:sequenceFlow id="Flow_T_Audit_End" sourceRef="Task_AuditTariffChange" targetRef="End_TariffChange" />
    <bpmn:association id="Assoc_T_Validate_Request" associationDirection="One" sourceRef="Task_ValidateTariffChange" targetRef="DS_Tariff_Request" />
    <bpmn:association id="Assoc_T_Validate_Tariff" associationDirection="One" sourceRef="Task_ValidateTariffChange" targetRef="DS_Tariff_Tariff" />
    <bpmn:association id="Assoc_T_ChargeSwitch_Billing" associationDirection="One" sourceRef="Task_ChargeSwitchFee" targetRef="DS_Tariff_BillingTransaction" />
    <bpmn:association id="Assoc_T_ChargeMonthly_Billing" associationDirection="One" sourceRef="Task_ChargeNewMonthlyFee" targetRef="DS_Tariff_BillingTransaction" />
    <bpmn:association id="Assoc_T_Update_Subscriber" associationDirection="One" sourceRef="Task_UpdateSubscriberTariff" targetRef="DS_Tariff_Subscriber" />
    <bpmn:association id="Assoc_T_Notify_Event" associationDirection="One" sourceRef="Task_NotifyTariffChange" targetRef="DS_Tariff_NotificationEvent" />
    <bpmn:association id="Assoc_T_Audit_Eis" associationDirection="One" sourceRef="Task_AuditTariffChange" targetRef="DS_Tariff_EisAudit" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_TariffChangeProcess">
    <bpmndi:BPMNPlane id="BPMNPlane_TariffChangeProcess" bpmnElement="TariffChangeProcess">
