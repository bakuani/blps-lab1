<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  targetNamespace="http://callmeani.urasha.ru/blps/camunda">

  <bpmn:process id="TariffChangeProcess" name="Tariff change" isExecutable="true">
    <bpmn:startEvent id="Start_TariffChange" name="Start tariff change">
      <bpmn:outgoing>Flow_T_Start_Form</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="UserTask_TariffChangeForm" name="Confirm tariff change" camunda:candidateGroups="SUBSCRIBER,OPERATOR,ADMIN">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="subscriberId" label="Subscriber id" type="long" />
          <camunda:formField id="targetTariffId" label="Target tariff id" type="long" />
          <camunda:formField id="options" label="Selected tariff options" type="string" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_T_Start_Form</bpmn:incoming>
      <bpmn:outgoing>Flow_T_Form_Validate</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="Task_ValidateTariffChange" name="Validate tariff change" camunda:type="external" camunda:topic="validate-tariff-change">
      <bpmn:incoming>Flow_T_Form_Validate</bpmn:incoming>
      <bpmn:outgoing>Flow_T_Validate_CanChange</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_CanChangeTariff" name="Can change tariff?">
      <bpmn:incoming>Flow_T_Validate_CanChange</bpmn:incoming>
      <bpmn:outgoing>Flow_T_CanChange_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_T_CanChange_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_HasSwitchFee" name="Has switch fee?">
      <bpmn:incoming>Flow_T_CanChange_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_T_SwitchFee_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_T_SwitchFee_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Task_ChargeSwitchFee" name="Charge switch fee" camunda:type="external" camunda:topic="charge-switch-fee">
      <bpmn:incoming>Flow_T_SwitchFee_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_T_SwitchFee_Merge</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_TariffChargesMerge">
      <bpmn:incoming>Flow_T_SwitchFee_Merge</bpmn:incoming>
      <bpmn:incoming>Flow_T_SwitchFee_No</bpmn:incoming>
      <bpmn:outgoing>Flow_T_Merge_MonthlyFee</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Task_ChargeNewMonthlyFee" name="Charge target tariff monthly fee" camunda:type="external" camunda:topic="charge-new-monthly-fee">
      <bpmn:incoming>Flow_T_Merge_MonthlyFee</bpmn:incoming>
      <bpmn:outgoing>Flow_T_Monthly_UpdateTariff</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_UpdateSubscriberTariff" name="Update subscriber tariff" camunda:type="external" camunda:topic="update-subscriber-tariff">
      <bpmn:incoming>Flow_T_Monthly_UpdateTariff</bpmn:incoming>
      <bpmn:outgoing>Flow_T_Update_Notify</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="Task_NotifyTariffChange" name="Send tariff notification" camunda:type="external" camunda:topic="send-notification">
      <bpmn:incoming>Flow_T_Update_Notify</bpmn:incoming>
      <bpmn:outgoing>Flow_T_Notify_Audit</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:serviceTask id="Task_AuditTariffChange" name="Publish tariff EIS audit" camunda:type="external" camunda:topic="publish-eis-audit">
      <bpmn:incoming>Flow_T_Notify_Audit</bpmn:incoming>
      <bpmn:incoming>Flow_T_CanChange_No</bpmn:incoming>
      <bpmn:outgoing>Flow_T_Audit_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_TariffChange" name="Tariff change finished">
      <bpmn:incoming>Flow_T_Audit_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_T_Start_Form" sourceRef="Start_TariffChange" targetRef="UserTask_TariffChangeForm" />
    <bpmn:sequenceFlow id="Flow_T_Form_Validate" sourceRef="UserTask_TariffChangeForm" targetRef="Task_ValidateTariffChange" />
    <bpmn:sequenceFlow id="Flow_T_Validate_CanChange" sourceRef="Task_ValidateTariffChange" targetRef="Gateway_CanChangeTariff" />
    <bpmn:sequenceFlow id="Flow_T_CanChange_Yes" sourceRef="Gateway_CanChangeTariff" targetRef="Gateway_HasSwitchFee">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${canChangeTariff}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T_CanChange_No" sourceRef="Gateway_CanChangeTariff" targetRef="Task_AuditTariffChange">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!canChangeTariff}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T_SwitchFee_Yes" sourceRef="Gateway_HasSwitchFee" targetRef="Task_ChargeSwitchFee">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${hasSwitchFee}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T_SwitchFee_No" sourceRef="Gateway_HasSwitchFee" targetRef="Gateway_TariffChargesMerge">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!hasSwitchFee}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T_SwitchFee_Merge" sourceRef="Task_ChargeSwitchFee" targetRef="Gateway_TariffChargesMerge" />
    <bpmn:sequenceFlow id="Flow_T_Merge_MonthlyFee" sourceRef="Gateway_TariffChargesMerge" targetRef="Task_ChargeNewMonthlyFee" />
    <bpmn:sequenceFlow id="Flow_T_Monthly_UpdateTariff" sourceRef="Task_ChargeNewMonthlyFee" targetRef="Task_UpdateSubscriberTariff" />
    <bpmn:sequenceFlow id="Flow_T_Update_Notify" sourceRef="Task_UpdateSubscriberTariff" targetRef="Task_NotifyTariffChange" />
    <bpmn:sequenceFlow id="Flow_T_Notify_Audit" sourceRef="Task_NotifyTariffChange" targetRef="Task_AuditTariffChange" />
    <bpmn:sequenceFlow id="Flow_T_Audit_End" sourceRef="Task_AuditTariffChange" targetRef="End_TariffChange" />
  </bpmn:process>

  <bpmn:process id="FeatureDisableProcess" name="Feature disable" isExecutable="true">
    <bpmn:startEvent id="Start_FeatureDisable" name="Start feature disable">
      <bpmn:outgoing>Flow_F_Start_Form</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="UserTask_FeatureDisableForm" name="Confirm feature disable" camunda:candidateGroups="SUBSCRIBER,OPERATOR,ADMIN">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="subscriberId" label="Subscriber id" type="long" />
          <camunda:formField id="featureId" label="Feature id" type="long" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_F_Start_Form</bpmn:incoming>
      <bpmn:outgoing>Flow_F_Form_Validate</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="Task_ValidateFeatureDisable" name="Validate feature disable" camunda:type="external" camunda:topic="validate-feature-disable">
      <bpmn:incoming>Flow_F_Form_Validate</bpmn:incoming>
      <bpmn:outgoing>Flow_F_Validate_CanDisable</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_CanDisableFeature" name="Can disable feature?">
      <bpmn:incoming>Flow_F_Validate_CanDisable</bpmn:incoming>
      <bpmn:outgoing>Flow_F_CanDisable_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_F_CanDisable_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Task_DisableFeatureBilling" name="Call billing for feature disable" camunda:type="external" camunda:topic="disable-feature-billing">
      <bpmn:incoming>Flow_F_CanDisable_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_F_Billing_Update</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_UpdateSubscriberFeature" name="Update subscriber feature" camunda:type="external" camunda:topic="update-subscriber-feature">
      <bpmn:incoming>Flow_F_Billing_Update</bpmn:incoming>
      <bpmn:outgoing>Flow_F_Update_Notify</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="Task_NotifyFeatureDisable" name="Send feature notification" camunda:type="external" camunda:topic="send-notification">
      <bpmn:incoming>Flow_F_Update_Notify</bpmn:incoming>
      <bpmn:outgoing>Flow_F_Notify_Audit</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:serviceTask id="Task_AuditFeatureDisable" name="Publish feature EIS audit" camunda:type="external" camunda:topic="publish-eis-audit">
      <bpmn:incoming>Flow_F_Notify_Audit</bpmn:incoming>
      <bpmn:incoming>Flow_F_CanDisable_No</bpmn:incoming>
      <bpmn:outgoing>Flow_F_Audit_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_FeatureDisable" name="Feature disable finished">
      <bpmn:incoming>Flow_F_Audit_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_F_Start_Form" sourceRef="Start_FeatureDisable" targetRef="UserTask_FeatureDisableForm" />
    <bpmn:sequenceFlow id="Flow_F_Form_Validate" sourceRef="UserTask_FeatureDisableForm" targetRef="Task_ValidateFeatureDisable" />
    <bpmn:sequenceFlow id="Flow_F_Validate_CanDisable" sourceRef="Task_ValidateFeatureDisable" targetRef="Gateway_CanDisableFeature" />
    <bpmn:sequenceFlow id="Flow_F_CanDisable_Yes" sourceRef="Gateway_CanDisableFeature" targetRef="Task_DisableFeatureBilling">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${canDisableFeature}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_F_CanDisable_No" sourceRef="Gateway_CanDisableFeature" targetRef="Task_AuditFeatureDisable">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!canDisableFeature}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_F_Billing_Update" sourceRef="Task_DisableFeatureBilling" targetRef="Task_UpdateSubscriberFeature" />
    <bpmn:sequenceFlow id="Flow_F_Update_Notify" sourceRef="Task_UpdateSubscriberFeature" targetRef="Task_NotifyFeatureDisable" />
    <bpmn:sequenceFlow id="Flow_F_Notify_Audit" sourceRef="Task_NotifyFeatureDisable" targetRef="Task_AuditFeatureDisable" />
    <bpmn:sequenceFlow id="Flow_F_Audit_End" sourceRef="Task_AuditFeatureDisable" targetRef="End_FeatureDisable" />
  </bpmn:process>

  <bpmn:process id="MonthlyFeeCycleProcess" name="Monthly fee cycle" isExecutable="true">
    <bpmn:startEvent id="Timer_MonthlyFeeCycle" name="Monthly fee timer">
      <bpmn:outgoing>Flow_MFC_Timer_CreateRequests</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/PT30S</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_CreateMonthlyFeeRequests" name="Create monthly fee requests" camunda:type="external" camunda:topic="create-monthly-fee-requests">
      <bpmn:incoming>Flow_MFC_Timer_CreateRequests</bpmn:incoming>
      <bpmn:outgoing>Flow_MFC_CreateRequests_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_MonthlyFeeCycle" name="Monthly fee requests created">
      <bpmn:incoming>Flow_MFC_CreateRequests_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_MFC_Timer_CreateRequests" sourceRef="Timer_MonthlyFeeCycle" targetRef="Task_CreateMonthlyFeeRequests" />
    <bpmn:sequenceFlow id="Flow_MFC_CreateRequests_End" sourceRef="Task_CreateMonthlyFeeRequests" targetRef="End_MonthlyFeeCycle" />
  </bpmn:process>

  <bpmn:process id="MonthlyFeeChargeProcess" name="Monthly fee charge" isExecutable="true">
    <bpmn:startEvent id="Start_MonthlyFeeCharge" name="Start monthly fee charge">
      <bpmn:outgoing>Flow_MF_Start_CreateInvoice</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="Task_CreateDolibarrInvoice" name="Create Dolibarr invoice" camunda:type="external" camunda:topic="create-dolibarr-invoice">
      <bpmn:incoming>Flow_MF_Start_CreateInvoice</bpmn:incoming>
      <bpmn:outgoing>Flow_MF_CreateInvoice_Charge</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_ChargeMonthlyFee" name="Charge monthly fee" camunda:type="external" camunda:topic="charge-monthly-fee">
      <bpmn:incoming>Flow_MF_CreateInvoice_Charge</bpmn:incoming>
      <bpmn:outgoing>Flow_MF_Charge_Gateway</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_MonthlyFeeSucceeded" name="Monthly fee succeeded?">
      <bpmn:incoming>Flow_MF_Charge_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_MF_Success_SyncInvoice</bpmn:outgoing>
      <bpmn:outgoing>Flow_MF_Failed_Audit</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Task_SyncDolibarrInvoice" name="Sync Dolibarr invoice" camunda:type="external" camunda:topic="sync-dolibarr-invoice">
      <bpmn:incoming>Flow_MF_Success_SyncInvoice</bpmn:incoming>
      <bpmn:outgoing>Flow_MF_Sync_Audit</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_AuditMonthlyFee" name="Publish monthly fee EIS audit" camunda:type="external" camunda:topic="publish-eis-audit">
      <bpmn:incoming>Flow_MF_Sync_Audit</bpmn:incoming>
      <bpmn:incoming>Flow_MF_Failed_Audit</bpmn:incoming>
      <bpmn:outgoing>Flow_MF_Audit_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_MonthlyFeeCharge" name="Monthly fee charge finished">
      <bpmn:incoming>Flow_MF_Audit_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_MF_Start_CreateInvoice" sourceRef="Start_MonthlyFeeCharge" targetRef="Task_CreateDolibarrInvoice" />
    <bpmn:sequenceFlow id="Flow_MF_CreateInvoice_Charge" sourceRef="Task_CreateDolibarrInvoice" targetRef="Task_ChargeMonthlyFee" />
    <bpmn:sequenceFlow id="Flow_MF_Charge_Gateway" sourceRef="Task_ChargeMonthlyFee" targetRef="Gateway_MonthlyFeeSucceeded" />
    <bpmn:sequenceFlow id="Flow_MF_Success_SyncInvoice" sourceRef="Gateway_MonthlyFeeSucceeded" targetRef="Task_SyncDolibarrInvoice">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${monthlyFeeSucceeded}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_MF_Failed_Audit" sourceRef="Gateway_MonthlyFeeSucceeded" targetRef="Task_AuditMonthlyFee">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!monthlyFeeSucceeded}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_MF_Sync_Audit" sourceRef="Task_SyncDolibarrInvoice" targetRef="Task_AuditMonthlyFee" />
    <bpmn:sequenceFlow id="Flow_MF_Audit_End" sourceRef="Task_AuditMonthlyFee" targetRef="End_MonthlyFeeCharge" />
  </bpmn:process>
</bpmn:definitions>
